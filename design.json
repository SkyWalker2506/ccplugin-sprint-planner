{
  "cds_version": "1.0",
  "name": "ccplugin-sprint-planner",
  "type": "plugin",
  "input_patterns": [
    {
      "type": "slash_command",
      "commands": [
        "/plan-sprint"
      ]
    },
    {
      "type": "auto_trigger",
      "keywords": [
        "sprint planning",
        "sprint plan",
        "backlog grooming"
      ],
      "confirm": false,
      "cooldown": 0
    }
  ],
  "output_patterns": [
    {
      "type": "terminal_text",
      "max_lines": 20
    },
    {
      "type": "file_generation",
      "path": "analysis/SPRINT_PLAN.md"
    },
    {
      "type": "structured_output",
      "description": "Jira epics/stories creation"
    }
  ],
  "lifecycle": {
    "preflight": {
      "required_tools": [
        "jq"
      ],
      "required_secrets": [
        "JIRA_URL",
        "JIRA_USERNAME",
        "JIRA_API_TOKEN"
      ],
      "required_mcp": [
        "atlassian"
      ]
    }
  },
  "error_handling": {
    "retry_network": true,
    "max_retries": 3
  }
}
